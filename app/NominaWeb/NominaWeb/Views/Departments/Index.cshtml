@model IEnumerable<NominaWeb.Models.Department>
@{
    ViewData["Title"] = "Departamentos";
}
<h1>Departamentos</h1>

@if (TempData["msg"] != null)
{
    <div style="padding:10px;border:1px solid #ccc;margin-bottom:10px;">
        @TempData["msg"]
    </div>
}

<p><a class="btn btn-primary" href="/Departments/Create">+ Nuevo departamento</a></p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>DeptNo</th>
            <th>Nombre</th>
            <th>Activo</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.DeptNo</td>
                <td>@d.DeptName</td>
                <td>@(d.IsActive ? "Sí" : "No")</td>
            </tr>
        }
    </tbody>
</table>